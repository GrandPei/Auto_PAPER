# ============================================================
# paper_downloader — 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据需要修改
#   cp .env.example .env
# ============================================================

# ---- 下载配置 ----
# PDF 保存目录（默认: papers）
PAPER_DOWNLOAD_DIR=papers

# 最大并发下载数（默认: 3）
PAPER_CONCURRENT=3

# 下载超时秒数（默认: 120）
PAPER_TIMEOUT=120

# 下载重试次数（默认: 3）
PAPER_RETRY=3

# ---- 缓存配置 ----
# 是否启用搜索缓存（默认: true）
PAPER_CACHE_ENABLED=true

# 缓存过期时间，秒（默认: 86400 = 24小时）
PAPER_CACHE_TTL=86400

# ---- 代理配置 ----
# HTTP 代理（默认: 空 = 不使用代理）
# PAPER_PROXY_HTTP=http://127.0.0.1:7890

# HTTPS 代理
# PAPER_PROXY_HTTPS=http://127.0.0.1:7890

# ---- 搜索引擎 ----
# 默认搜索引擎，逗号分隔（默认: arxiv,crossref,google_scholar）
# 可选值: arxiv, crossref, google_scholar
PAPER_ENGINES=arxiv,crossref

# ---- 日志 ----
# 日志级别: DEBUG | INFO | WARNING | ERROR（默认: INFO）
PAPER_LOG_LEVEL=INFO
