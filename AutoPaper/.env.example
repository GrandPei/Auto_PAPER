# ═══════════════════════════════════════════════════════════════
# AutoPaper — 环境变量配置模板
# ═══════════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── API Keys ──────────────────────────────────────────────────

# Deepseek API Key（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Semantic Scholar API Key（可选，不填也可使用免费 API）
SEMANTIC_SCHOLAR_API_KEY=

# SerpAPI Key（可选，用于 Google Scholar PDF 下载渠道）
SERPAPI_API_KEY=

# ── 外部数据源 ────────────────────────────────────────────────

# OpenAlex 礼貌邮箱（推荐填写）
OPENALEX_EMAIL=your-email@example.com

# ArXiv API 联系邮箱（可选）
ARXIV_CONTACT=

# ── Deepseek ──────────────────────────────────────────────────

# API 基础地址（一般无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 默认模型
DEEPSEEK_MODEL=deepseek-chat

# 最大重试次数
DEEPSEEK_MAX_RETRIES=3

# 请求超时秒数
DEEPSEEK_TIMEOUT=60

# ── 下载与存储 ────────────────────────────────────────────────

# 论文 PDF 下载目录（相对路径相对于项目根）
DOWNLOAD_DIR=./papers

# ── 日志 ──────────────────────────────────────────────────────

# 日志等级: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# 日志格式（一般无需修改）
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s

# 日志时间格式
LOG_DATEFMT=%Y-%m-%d %H:%M:%S
